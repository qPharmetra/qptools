;; 1. Based on: 14
;; 2. Description:
;;    IIV on KOUT- prelim Cohort 3 CD4+
;; 3. Label:
;;    1 cpt input turnover model
;; 4. Structural model:
;;    1 cpt input turnover model
;; 5. Covariate model:
;; 6. Inter-individual variability:
;;    CL, V
;; 7. Inter-occasion variability:
;;    NONE
;; 8. Residual variability:
;;    Additive on log scale
;; 9. Estimation:
;;    FOCE
$PROBLEM    ABCURO PKPD MODELING
$INPUT      ID SUBJID=DROP TIME DV BQL EVID AMT TYPE DAY COUNTBASE
            COUNTCFB COUNTPCFB PLACEBO DOSE WT CL V KA LNDV
$DATA      nm_pkpd_cohort2b_indpk.csv IGNORE=@ IGNORE=(BQL.EQ.1)
            IGNORE=(TYPE.EQ.1) IGNORE=(TYPE.GT.2)
            IGNORE=(PLACEBO.EQ.1)
$SUBROUTINE ADVAN13 TOL=12
$ABBREVIATED COMRES=1
$MODEL      COMP(depot,DEFDOSE) COMP(PLASMA) COMP(TC1) COMP(TC2)
            COMP(TC3) COMP(KLRG1PLASMA)
$PK                    

TVPD0  = THETA(1)
TVTHALF = THETA(2)

; PK compartment
F1 = EXP(1.1)/(1+EXP(1.1)) ; this was fixed to that value in run4

;P D model components
MU_1 = TVPD0 ; PD0
MU_2 = TVTHALF ; KOUT
MU_3 = THETA(3) ; EMAX
MU_4 = THETA(4) ; EC50
MU_5 = THETA(5) ; KTR

ERR_ADD = THETA(6)
ERR_PROP = THETA(7)

; Effect parameters and initiation
PD0  = EXP(MU_1+ETA(1))
THALF = EXP(MU_2+ETA(2))
EMAX = EXP(MU_3+ETA(3)) ; simple scalar of drug effect
KOUT = LOG(2)/THALF
MAXEFF = (1/(1-1/100)-1)

KIN = KOUT * PD0
A_0(6) = PD0

EC50 = EXP(MU_4+ETA(4))
KTR = EXP(MU_5+ETA(5))

; Capture dose time
IF(NEWIND.NE.2) COM(1)=TIME
IF(EVID.EQ.1) COM(1)=TIME

$DES   

C2 = A(2)/V * 1000

DADT(1) = - KA*A(1)
DADT(2) =   KA*A(1) - CL*C2
DADT(3) = KIN - KTR*A(3) 
DADT(4) = KTR*A(3) - KTR*A(4) 
DADT(5) = KTR*A(4) - KTR*A(5) 
DADT(6) = KTR*A(5) - KOUT*A(6) - EMAX*C2/(EC50+C2)

$ERROR                
IPRED = A(6)
AEFF = IPRED
W = sqrt(ERR_ADD**2 + ERR_PROP**2 * IPRED**2)
 
IF(IPRED.LT.0) THEN
  IPRED=0
  W=1
ENDIF 

Y = IPRED+W*EPS(1)
IRES = DV - IPRED
IWRES = IRES/W

$THETA  (1,3.09018,7) ; PD0; Base count; LOG
$THETA  6.36184 ; THALF KOUT; h; LOG
$THETA  (-5,-1.5075,5) ; EMAX; prlwstz; LOG
$THETA  1 FIX ; EC50; ng/L; LOG
$THETA  -1.53008 ; KTR; 1/h; LOG
$THETA  0 FIX ; Additive error (log); cells/L; LIN
$THETA  0.404737 ; Proportional error; ; LIN
$OMEGA  0.416064  ;   IIV(PD0)
 0.09  ;  IIV(KOUT)
 0.359259  ;  IIV(EMAX)
 0  FIX  ;  IIV(EC50)
 0  FIX  ;   IIV(KTR)
$SIGMA  1  FIX  ;      SIGMA
$ESTIMATION METHOD=COND INTER NSIG=3 SIGL=9 MAXEVALS=9999 PRINT=1
            NOABORT
$COVARIANCE PRINT=E UNCONDITIONAL MATRIX=S
$TABLE      ID TIME EVID PRED IPRED RES IRES WRES IWRES CWRES DV MDV
            C2 FORMAT=s1PG15.8 NOAPPEND NOPRINT ONEHEADER FILE=sdtab15
$TABLE      ID DOSE V CL KA AEFF ETAS(1:LAST) FORMAT=s1PE13.7 NOAPPEND
            ONEHEADER NOPRINT FORMAT=s1PG15.8 FILE=patab15
$TABLE      ID TIME DV IPRED EVID CWRES IWRES DOSE WT AMT
            FORMAT=S1PG15.8 NOAPPEND ONEHEADER NOPRINT FILE=cotab15
$TABLE      ID TYPE NOPRINT ONEHEADER FORMAT=S1PG15.8 FILE=catab15

  

$THETA  0.694525 FIX ; F1EXP_TAP; 74
$THETA  0.954398 ; IIV_RBAEXP_FB; 75
$THETA  1.43589 ; IIV_RBAEXP_NB; 76
$THETA  0.436359 ; ST203_F1BUP; 77
